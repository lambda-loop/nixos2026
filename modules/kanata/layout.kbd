(deflayer (base-layer)
 esc  f1   f2   f3   f4   f5   f6   f7   f8   f9   f10  f11  f12  del   
 grv  1    2    3    4    5    6    7    8    9    0    -    =    bspc  home 
 tab  q    w    e    r    t    y    u    i    o    p    [    ]    ralt  mlft 
 esc  a    s    d    f    g    h    j    k    l    ;    '    ret        mlft
 lsft z    x    c    v    b    n    m    ,    .    /   @fsft     up     end
 lctl lalt @xhyper       spc         @zellik lalt rctl    left  down  right
 )

